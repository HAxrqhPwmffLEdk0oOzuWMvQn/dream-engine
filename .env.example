# Dream Engine Configuration
# Copy to .env and edit, or run `uv run dream` for interactive setup.

# Project paths to scan (comma-separated)
DREAM_SCAN_PATHS=~/Desktop

# Claude Code model for deep analysis (opus, sonnet, haiku)
DREAM_CLAUDE_MODEL=opus

# Projects per nightly dream run (more = wider coverage, higher cost)
DREAM_NIGHTLY_BATCH_SIZE=10

# Optional: Wiki.js integration
# Push project knowledge to a Wiki.js instance
DREAM_WIKI_ENABLED=false
DREAM_WIKI_UPDATE_SCRIPT=~/bin/wiki-update.sh
DREAM_WIKI_EXPORT_SCRIPT=~/bin/wiki-export-for-claude.sh

# Optional: ElizaOS/Milady integration
# Inject knowledge into an ElizaOS agent's memory system
DREAM_MILADY_ENABLED=false
DREAM_MILADY_API_URL=http://localhost:2138
